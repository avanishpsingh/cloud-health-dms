# ─────────────────────────────────────────────────────────────────────────────
# Healthcare DMS — Environment Variables
# Copy this file to .env and fill in values before running.
# For a local demo you only need the defaults already set here.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=Healthcare DMS
DEBUG=true

# ── Database ─────────────────────────────────────────────────────────────────
# Local (default — no AWS needed):
DATABASE_URL=sqlite:///./health_dms.db
# PostgreSQL (Phase 2 / AWS RDS):
# DATABASE_URL=postgresql://user:password@rds-hostname:5432/healthdms

# ── JWT Auth ─────────────────────────────────────────────────────────────────
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── File Uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# ── Storage Backend ───────────────────────────────────────────────────────────
# "local"  → files saved to UPLOAD_DIR (Phase 1 / demo)
# "s3"     → files uploaded to S3 (Phase 2 / AWS)
STORAGE_BACKEND=local
S3_BUCKET=
S3_PREFIX=medical-records/
S3_KMS_KEY_ID=
AWS_REGION=ap-south-1

# ── Notifications (Phase 2) ───────────────────────────────────────────────────
SNS_TOPIC_ARN=

# ── Logging ───────────────────────────────────────────────────────────────────
# JSON_LOGS=true  →  CloudWatch-friendly JSON (set this on EC2)
JSON_LOGS=false
LOG_LEVEL=INFO
